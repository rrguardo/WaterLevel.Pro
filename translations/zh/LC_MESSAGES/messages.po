"                <div class=\"row justify-content-md-center my-3\">\n"
"                    <div class=\"col-md-auto my-2\">\n"
"                        Requires: <span class=\"badge text-bg-success fw-"
"bold\">Smart On</span> and <span class=\"badge text-bg-danger fw-"
"bold\">Smart Mode</span>\n"
"                    </div>\n"
"                </div>\n"
"                "
