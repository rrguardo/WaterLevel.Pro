#: templates/relay_device_info.html:458
msgid "Safe Run"
msgstr "Funcionamiento Seguro"

#: templates/relay_device_info.html:461
#, fuzzy
msgid ""
"\n"
"                <p class=\"ms-4 my-3 alert alert-info\" role=\"alert\">\n"
"                    In safe mode, the <span class=\"badge text-bg-danger "
"fw-bold\">Smart Mode</span>\n"
"                    will be disabled, and the pump will turn <b>OFF</b> "
"if the device moves beyond the <b>blind area</b> by more\n"
"                    than <b>2 centimeters</b>, or if the sensor reports "
"<b>zero distance</b> (indicating a disconnected sensor cable).\n"
"                </p>\n"
"                <div class=\"row justify-content-md-center my-3\">\n"
"                    <div class=\"col-md-auto my-2\">\n"
"                        Requires: <span class=\"badge text-bg-primary fw-"
"bold\">Smart Off</span>\n"
"                    </div>\n"
"                    <div class=\"col-md-auto my-2\">\n"
"                        Don't Depends On: <span class=\"badge text-bg-"
"danger fw-bold\">Smart Mode</span>\n"
"                    </div>\n"
"                </div>\n"
"                "
msgstr ""
"\n"
"                <p class=\"ms-4 my-3 alert alert-info\" role=\"alert\">\n"
"                    En el modo seguro, el <span class=\"badge text-bg-"
"danger fw-bold\">Modo Inteligente</span>\n"
